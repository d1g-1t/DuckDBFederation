APP_NAME=ParquetFederation
DEBUG=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

FEDERATION_PG_DSN=host=postgres port=5432 dbname=federation_source user=reader password=reader_password

DUCKDB_MEMORY_LIMIT=4GB
DUCKDB_THREADS=4
DUCKDB_SPILL_DIR=/tmp/duckdb_spill
DUCKDB_POOL_SIZE=10

DEFAULT_QUERY_TIMEOUT=30
MAX_QUERY_TIMEOUT=300
MAX_RESULT_ROWS=100000
